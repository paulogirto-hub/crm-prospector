{
    "name": "prospec/crm",
    "description": "Prospec CRM — Sistema de Prospecção Comercial B2B",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-curl": "*",
        "ext-redis": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Core/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "migrate": "php database/migrate.php",
        "seed": "php scripts/seed.php",
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "phpunit/phpunit": true
        }
    }
}